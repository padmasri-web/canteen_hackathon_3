<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="student-layout">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="font-size: 28px;">Admin Control Center</h2>
                <p style="color: var(--text-muted); font-size: 14px;">Real-time performance metrics and operations dashboard</p>
            </div>
            <div style="background-color: var(--primary-glow); color: var(--primary); padding: 8px 16px; border-radius: var(--radius-sm); font-weight: 700; font-size: 14px;">
                🔴 System Live
            </div>
        </div>
        
        <!-- Metrics Grid -->
        <div class="admin-metrics">
            <!-- Total Orders -->
            <div class="metric-card orders">
                <div class="metric-info">
                    <h3>Total Orders</h3>
                    <div class="metric-val"><%= totalOrders %></div>
                </div>
                <div class="metric-icon-box">📦</div>
            </div>

            <!-- Pending Orders -->
            <div class="metric-card pending">
                <div class="metric-info">
                    <h3>Pending Orders</h3>
                    <div class="metric-val"><%= pendingOrders %></div>
                </div>
                <div class="metric-icon-box">⏳</div>
            </div>

            <!-- Revenue -->
            <div class="metric-card revenue">
                <div class="metric-info">
                    <h3>Today's Revenue</h3>
                    <div class="metric-val">₹<%= revenue.toLocaleString('en-IN') %></div>
                </div>
                <div class="metric-icon-box">💰</div>
            </div>
        </div>
        
        <!-- Action Pathways Grid -->
        <h3 style="margin-bottom: 20px; font-size: 20px;">Administrative Actions</h3>