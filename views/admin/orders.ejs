<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="student-layout">
    <div class="container">
        <div class="admin-orders-header">
            <div>
                <h2 style="font-size: 28px;">Live Canteen Orders</h2>
                <p style="color: var(--text-muted); font-size: 14px;">Toggle status to notify students in real-time</p>
            </div>
            
            <div class="admin-orders-tabs">
                <button class="admin-orders-tab active" onclick="filterOrders('all', this)">All (<%= orders.length %>)</button>
                <button class="admin-orders-tab" onclick="filterOrders('pending', this)">Pending (<%= orders.filter(o => o.status !== 'Delivered').length %>)</button>
                <button class="admin-orders-tab" onclick="filterOrders('completed', this)">Completed (<%= orders.filter(o => o.status === 'Delivered').length %>)</button>
            </div>
        </div>

        <div class="admin-order-cards-grid">
            <% if (orders.length === 0) { %>
                <p style="color: var(--text-muted); font-size: 16px;">No orders yet.</p>
            <% } %>

            <% orders.forEach(order => { %>
            <div class="admin-order-card" data-status="<%= order.status === 'Delivered' ? 'completed' : 'pending' %>">
                <div class="admin-order-header">
                    <span class="admin-order-token">Token #<%= order.token %></span>
                    <span class="status-pill <%= order.status.toLowerCase() %>" id="status-<%= order._id %>">
                        <%= order.status %>
                    </span>
                </div>

                <div class="admin-order-body">
                    <ul class="admin-order-items">
                        <% order.items.forEach(item => { %>
                        <li class="admin-order-item">
                            <span><strong class="item-qty"><%= item.quantity %>x</strong> <%= item.name %></span>
                            <span>₹<%= item.price * item.quantity %></span>
                        </li>
                        <% }) %>
                    </ul>
                    <div class="admin-order-total-row">
                        <span>Grand Total</span>
                        <span>₹<%= order.totalAmount %></span>
                    </div>
                </div>

                <div class="admin-order-actions">
                    <button class="action-btn prepare <%= order.status === 'Preparing' ? 'active' : '' %>"
                        onclick="updateStatus('<%= order._id %>', 'Preparing', this)">Preparing</button>

                    <button class="action-btn ready <%= order.status === 'Ready' ? 'active' : '' %>"
                        onclick="updateStatus('<%= order._id %>', 'Ready', this)">Ready</button>

                    <button class="action-btn deliver <%= order.status === 'Delivered' ? 'active' : '' %>"
                        onclick="updateStatus('<%= order._id %>', 'Delivered', this)">Delivered</button>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</main>

<script>
    function filterOrders(category, tabBtn) {
        document.querySelectorAll('.admin-orders-tab').forEach(tab => {
            tab.classList.remove('active');
        });
        tabBtn.classList.add('active');

        document.querySelectorAll('.admin-order-card').forEach(card => {
            const status = card.getAttribute('data-status');
            if (category === 'all') {
                card.style.display = 'flex';
            } else if (category === 'pending' && status === 'pending') {
                card.style.display = 'flex';
            } else if (category === 'completed' && status === 'completed') {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    async function updateStatus(orderId, status, btnElement) {
        try {
            const res = await fetch(`/admin/orders/${orderId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });

            if (res.ok) {
                // Update active button
                const actionContainer = btnElement.closest('.admin-order-actions');
                actionContainer.querySelectorAll('.action-btn').forEach(b => b.classList.remove('active'));
                btnElement.classList.add('active');

                // Update status badge
                const badge = document.getElementById(`status-${orderId}`);
                badge.className = `status-pill ${status.toLowerCase()}`;
                badge.innerText = status;

                // Update card's data-status for filter
                const card = btnElement.closest('.admin-order-card');
                card.setAttribute('data-status', status === 'Delivered' ? 'completed' : 'pending');
            } else {
                alert('Failed to update status. Try again.');
            }
        } catch (err) {
            console.error('Status update error:', err);
            alert('Network error. Try again.');
        }
    }
</script>

<%- include("../partials/footer") %>