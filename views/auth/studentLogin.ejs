<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">⚡ Student Portal</h2>
            <p class="auth-subtitle">Login or create an account to place canteen orders</p>
        </div>

        <!-- Tab Toggle -->
        <div class="auth-tabs">
            <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">Login</button>
            <button class="auth-tab" id="tab-register" onclick="switchTab('register')">Register</button>
        </div>

        <!-- Alert Box -->
        <div id="auth-alert" class="auth-alert" style="display:none;"></div>

        <!-- LOGIN FORM -->
        <form id="form-login" action="/api/auth/login" method="POST">
            <div class="form-group">
                <label for="login-email" class="form-label">Email Address</label>
                <input type="email" id="login-email" name="email" class="form-input"
                    placeholder="student@college.edu" required>
            </div>
            <div class="form-group">
                <label for="login-password" class="form-label">Password / PIN</label>
                <input type="password" id="login-password" name="password" class="form-input"
                    placeholder="Enter your password (default: 123456)" required>
            </div>
            <button type="submit" class="auth-btn student">
                Log In →
            </button>
        </form>

        <!-- REGISTER FORM -->
        <form id="form-register" style="display:none;" onsubmit="handleRegister(event)">
            <div class="form-group">
                <label for="reg-name" class="form-label">Full Name</label>
                <input type="text" id="reg-name" name="name" class="form-input"
                    placeholder="Your full name" required>
            </div>
            <div class="form-group">
                <label for="reg-email" class="form-label">Email Address</label>
                <input type="email" id="reg-email" name="email" class="form-input"
                    placeholder="student@college.edu" required>
            </div>
            <div class="form-group">
                <label for="reg-password" class="form-label">Password / PIN</label>
                <input type="password" id="reg-password" name="password" class="form-input"
                    placeholder="Choose a password (or use 123456)" required>
            </div>
            <button type="submit" id="btn-register" class="auth-btn student">
                Create Account →
            </button>
        </form>

        <div class="auth-footer">
            <p>Are you an Administrator? <a href="/auth/adminLogin">Admin Login</a></p>
            <p style="margin-top: 10px;"><a href="/">← Back to Home</a></p>
        </div>
    </div>
</main>

<style>
    .auth-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 24px;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid var(--primary, #3c0c54);
    }
    .auth-tab {
        flex: 1;
        padding: 10px 0;
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 15px;
        font-weight: 600;
        color: var(--primary, #3c0c54);
        transition: all 0.2s;
    }
    .auth-tab.active {
        background: var(--primary, #3c0c54);
        color: white;
    }
    .auth-alert {
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 16px;
        font-size: 14px;
        font-weight: 500;
    }
    .auth-alert.success { background: #e8f5e9; color: #2e7d32; }
    .auth-alert.error   { background: #fce4ec; color: #c62828; }
</style>

<script>
    function switchTab(tab) {
        const loginForm     = document.getElementById('form-login');
        const registerForm  = document.getElementById('form-register');
        const tabLogin      = document.getElementById('tab-login');
        const tabRegister   = document.getElementById('tab-register');
        const alert         = document.getElementById('auth-alert');

        alert.style.display = 'none';

        if (tab === 'login') {
            loginForm.style.display    = 'block';
            registerForm.style.display = 'none';
            tabLogin.classList.add('active');
            tabRegister.classList.remove('active');
        } else {
            loginForm.style.display    = 'none';
            registerForm.style.display = 'block';
            tabRegister.classList.add('active');
            tabLogin.classList.remove('active');
        }
    }

    function showAlert(msg, isSuccess) {
        const el = document.getElementById('auth-alert');
        el.innerText = msg;
        el.className = 'auth-alert ' + (isSuccess ? 'success' : 'error');
        el.style.display = 'block';
    }

    async function handleRegister(e) {
        e.preventDefault();
        const btn      = document.getElementById('btn-register');
        const email    = document.getElementById('reg-email').value.trim();
        const password = document.getElementById('reg-password').value.trim();
        const name     = document.getElementById('reg-name').value.trim();

        if (!email || !password || !name) {
            return showAlert('Please fill in all fields.', false);
        }

        btn.disabled  = true;
        btn.innerText = 'Creating account...';

        try {
            // Step 1: Register
            const regRes  = await fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ email, password })
            });
            const regData = await regRes.json();

            if (!regRes.ok || !regData.success) {
                return showAlert(regData.message || 'Registration failed. Try a different email.', false);
            }

            // Step 2: Save name
            await fetch('/api/auth/save-name', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            });

            showAlert('Account created! Redirecting...', true);
            setTimeout(() => window.location.href = '/student/menu', 800);
        } catch (err) {
            showAlert('Connection error. Is the server running?', false);
        } finally {
            btn.disabled  = false;
            btn.innerText = 'Create Account →';
        }
    }
</script>

<%- include("../partials/footer") %>
