<%- include("../partials/header") %>
    <%- include("../partials/navbar") %>

        <main class="student-layout">
            <div class="container">

                <h2 style="margin-bottom: 24px;">Your Cart 🛒</h2>

                <div id="cartContainer"></div>

                <div id="cartSummary" style="margin-top: 30px; display: none;">
                    <h3>Total: ₹<span id="cartTotal">0</span></h3>

                    <button id="clearCartBtn" class="add-btn" style="margin-top: 12px;">
                        Clear Cart
                    </button>

                    <a href="/student/menu" class="checkout-link" style="margin-left: 10px;">
                        Add More Items
                    </a>

                    <a href="/student/payment"> <button class="add-btn" style="margin-left: 10px;">
                            Place Order
                        </button>
                    </a>
                </div>

            </div>
        </main>

        <script>
            function getCart() {
                return JSON.parse(localStorage.getItem("canteen_cart") || "[]");
            }

            function saveCart(cart) {
                localStorage.setItem("canteen_cart", JSON.stringify(cart));
                renderCart();
            }

            function renderCart() {
                const cart = getCart();

                const cartContainer = document.getElementById("cartContainer");
                const cartSummary = document.getElementById("cartSummary");
                const cartTotal = document.getElementById("cartTotal");

                cartContainer.innerHTML = "";

                if (cart.length === 0) {
                    cartContainer.innerHTML = `
                <div style="text-align:center; margin-top:40px;">
                    <h3>Your cart is empty 😭</h3>
                    <p>Add some tasty items from the menu.</p>
                    <a href="/student/menu" class="checkout-link">Go to Menu</a>
                </div>
            `;

                    cartSummary.style.display = "none";
                    return;
                }

                let total = 0;

                cart.forEach((item, index) => {
                    total += item.price * item.qty;

                    const cartItem = document.createElement("div");
                    cartItem.className = "food-card";
                    cartItem.style.marginBottom = "16px";

                    cartItem.innerHTML = `
                <div class="food-card-content">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:20px;">

                        <div style="display:flex; align-items:center; gap:16px;">
                            ${item.image && item.image.startsWith("http") ? `
                                <img src="${item.image}" alt="${item.name}" class="cart-item-img">
                            ` : `
                                <div style="font-size:42px; width:64px; height:64px; display:flex; align-items:center; justify-content:center;">
                                    ${item.image || "🍽️"}
                                </div>
                            `}

                            <div>
                                <h3 class="food-title">${item.name}</h3>
                                <p class="food-desc">${item.category || "Canteen Item"}</p>
                                <div class="food-price">₹${item.price}</div>
                            </div>
                        </div>

                        <div style="display:flex; align-items:center; gap:10px;">
                            <button class="add-btn decrease-btn" data-index="${index}">-</button>
                            <span style="font-size:18px; font-weight:600;">${item.qty}</span>
                            <button class="add-btn increase-btn" data-index="${index}">+</button>
                            <button class="add-btn remove-btn" data-index="${index}" style="background:#ff4d4d; color:white;">
                                Delete
                            </button>
                        </div>

                    </div>
                </div>
            `;

                    cartContainer.appendChild(cartItem);
                });

                cartTotal.innerText = total;
                cartSummary.style.display = "block";

                attachCartButtons();
            }

            function attachCartButtons() {
                document.querySelectorAll(".increase-btn").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const index = this.dataset.index;
                        let cart = getCart();

                        cart[index].qty += 1;

                        saveCart(cart);
                    });
                });

                document.querySelectorAll(".decrease-btn").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const index = this.dataset.index;
                        let cart = getCart();

                        cart[index].qty -= 1;

                        if (cart[index].qty <= 0) {
                            cart.splice(index, 1);
                        }

                        saveCart(cart);
                    });
                });

                document.querySelectorAll(".remove-btn").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const index = this.dataset.index;
                        let cart = getCart();

                        cart.splice(index, 1);

                        saveCart(cart);
                    });
                });
            }

            document.addEventListener("DOMContentLoaded", () => {
                renderCart();

                const clearCartBtn = document.getElementById("clearCartBtn");

                clearCartBtn.addEventListener("click", () => {
                    localStorage.removeItem("canteen_cart");
                    renderCart();
                });
            });
        </script>

        <%- include("../partials/footer") %>