<%- include("../partials/header") %>
    <%- include("../partials/navbar") %>

        <main class="student-layout">
            <div class="container">

                <!-- Categories Selector -->
                <div class="categories-container">
                    <button class="category-pill active" data-category="all">⚡ All Items</button>
                    <button class="category-pill" data-category="fastfood">🍔 Fast Food</button>
                    <button class="category-pill" data-category="beverages">☕ Beverages</button>
                    <button class="category-pill" data-category="snacks">🥪 Snacks</button>
                    <button class="category-pill" data-category="meals">🍕 Meals</button>
                </div>

                <h2 style="margin-bottom: 24px;">Recommended For You</h2>

                <div class="grid-menu">

                    <% if (menuItems.length===0) { %>
                        <p>No menu items available right now.</p>
                        <% } %>

                            <% menuItems.forEach(item=> { %>

                                <div class="food-card" data-category="<%= item.category %>">

                                    <% if (item.isBestseller) { %>
                                        <span class="food-badge">Bestseller</span>
                                        <% } %>

                                            <div class="food-image-wrapper flex-center"
                                                style="background: linear-gradient(135deg, #ffe0b2 0%, #ffb74d 100%);">

                                                <% if (item.image && item.image.startsWith("http")) { %>
                                                    <img src="<%= item.image %>" alt="<%= item.itemName %>"
                                                        style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;">
                                                    <% } else { %>
                                                        <span
                                                            style="font-size: 64px; animation: float 6s ease-in-out infinite;">
                                                            <%= item.image || "🍽️" %>
                                                        </span>
                                                        <% } %>

                                            </div>

                                            <div class="food-card-content">
                                                <h3 class="food-title">
                                                    <%= item.itemName %>
                                                </h3>

                                                <p class="food-desc">
                                                    <%= item.description || "Fresh and tasty canteen item." %>
                                                </p>

                                                <div class="food-card-footer">
                                                    <div class="food-price">
                                                        <span>₹</span>
                                                        <%= item.price %>
                                                    </div>

                                                    <form action="" method="POST" class="add-to-cart-form">
                                                        <input type="hidden" name="itemId" value="<%= item._id %>">
                                                        <input type="hidden" name="itemName"
                                                            value="<%= item.itemName %>">
                                                        <input type="hidden" name="price" value="<%= item.price %>">
                                                        <input type="hidden" name="image"
                                                            value="<%= item.image || '🍽️' %>">
                                                        <input type="hidden" name="category"
                                                            value="<%= item.category %>">

                                                        <button type="submit" class="add-btn">ADD</button>
                                                    </form>
                                                </div>
                                            </div>
                                </div>

                                <% }) %>

                </div>
            </div>
        </main>

        <!-- Floating Cart Bar -->
        <div class="checkout-bar-floating" id="floatingCart">
            <div class="checkout-bar-info">
                <span class="checkout-items" id="cartCountText">0 Items added</span>
                <span class="checkout-total-price" id="cartTotalPrice">₹0</span>
            </div>

            <a href="/student/cart" class="checkout-link">
                View Cart ➡️
            </a>
        </div>

        <script>
            function getCart() {
                return JSON.parse(localStorage.getItem("canteen_cart") || "[]");
            }

            function saveCart(cart) {
                localStorage.setItem("canteen_cart", JSON.stringify(cart));
                updateFloatingBar();
            }

            function updateFloatingBar() {
                const cart = getCart();

                const bar = document.getElementById("floatingCart");
                const countText = document.getElementById("cartCountText");
                const totalText = document.getElementById("cartTotalPrice");

                if (!bar || !countText || !totalText) return;

                if (cart.length > 0) {
                    const totalItems = cart.reduce((acc, item) => acc + item.qty, 0);
                    const totalPrice = cart.reduce((acc, item) => acc + item.price * item.qty, 0);

                    countText.innerText = `${totalItems} Item${totalItems > 1 ? "s" : ""} added`;
                    totalText.innerText = `₹${totalPrice}`;
                    bar.classList.add("show");
                } else {
                    bar.classList.remove("show");
                }
            }

            document.querySelectorAll(".add-to-cart-form").forEach(form => {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();

                    const itemId = this.querySelector('input[name="itemId"]').value;
                    const name = this.querySelector('input[name="itemName"]').value;
                    const price = Number(this.querySelector('input[name="price"]').value);
                    const image = this.querySelector('input[name="image"]').value;
                    const category = this.querySelector('input[name="category"]').value;

                    let cart = getCart();

                    const existingItem = cart.find(item => item.itemId === itemId);

                    if (existingItem) {
                        existingItem.qty += 1;
                    } else {
                        cart.push({
                            itemId,
                            name,
                            price,
                            image,
                            category,
                            qty: 1
                        });
                    }

                    saveCart(cart);

                    const btn = this.querySelector(".add-btn");
                    const originalText = btn.innerText;

                    btn.innerText = "ADDED ✓";
                    btn.style.backgroundColor = "var(--accent)";
                    btn.style.color = "white";

                    setTimeout(() => {
                        btn.innerText = originalText;
                        btn.style.backgroundColor = "";
                        btn.style.color = "";
                    }, 1000);
                });
            });

            // Category filter
            const categoryButtons = document.querySelectorAll(".category-pill");
            const foodCards = document.querySelectorAll(".food-card");

            categoryButtons.forEach(button => {
                button.addEventListener("click", () => {
                    const selectedCategory = button.dataset.category;

                    categoryButtons.forEach(btn => btn.classList.remove("active"));
                    button.classList.add("active");

                    foodCards.forEach(card => {
                        const cardCategory = card.dataset.category;

                        if (selectedCategory === "all" || cardCategory === selectedCategory) {
                            card.style.display = "block";
                        } else {
                            card.style.display = "none";
                        }
                    });
                });
            });

            document.addEventListener("DOMContentLoaded", updateFloatingBar);
        </script>

        <!-- Student OTP Authentication Modal Overlay -->
        <% if (typeof session==='undefined' || !session.isStudent || !session.studentName) { %>
            <div id="student-auth-overlay" class="auth-overlay">
                <div class="auth-modal-card">
                    <div class="auth-modal-header">
                        <h3 class="auth-modal-title">⚡ Student Login / Register</h3>
                        <p class="auth-modal-subtitle">Enter your email — new users are registered automatically</p>
                    </div>

                    <div class="auth-modal-body">
                        <!-- Alert message container -->
                        <div id="auth-alert" class="auth-alert" style="display: none;"></div>

                        <!-- Step 1: Email Input Section -->
                        <div id="auth-step-email" class="auth-step"
                            style="<%= (typeof session !== 'undefined' && session.isStudent) ? 'display: none;' : '' %>">
                            <div class="form-group">
                                <label for="auth-email" class="form-label">Student Email Address</label>
                                <input type="email" id="auth-email" class="form-input"
                                    placeholder="Enter student email (e.g. name@college.edu)" required>
                            </div>
                            <button type="button" id="btn-send-otp" class="auth-btn student">
                                Continue →
                            </button>
                        </div>

                        <!-- Step 2: OTP Input Section -->
                        <div id="auth-step-otp" class="auth-step" style="display: none;">
                            <div class="form-group">
                                <label for="auth-otp" class="form-label">Password / PIN</label>
                                <input type="text" id="auth-otp" class="form-input" placeholder="Enter password (default: 123456)"
                                    maxLength="6" required>
                            </div>
                            <div class="auth-modal-resend">
                                Wrong email? <button type="button" id="btn-resend-otp"
                                    class="resend-link">Go Back</button>
                            </div>
                            <button type="button" id="btn-verify-otp" class="auth-btn student">
                                Login / Register ✓
                            </button>
                        </div>

                        <!-- Step 3: Name Input Section -->
                        <div id="auth-step-name" class="auth-step"
                            style=" <%= (typeof session !== 'undefined' && session.isStudent && !session.studentName) ? 'display: flex;' : 'display: none;' %>">
                            <div class="form-group">
                                <label for="auth-name" class="form-label">Your Full Name</label>
                                <input type="text" id="auth-name" class="form-input" placeholder="Enter your full name"
                                    required>
                            </div>
                            <button type="button" id="btn-save-name" class="auth-btn student">
                                Continue to Menu ➔
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <script src="/js/studentAuth.js" defer></script>
            <% } %>

                <%- include("../partials/footer") %>